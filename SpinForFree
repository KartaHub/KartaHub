--Skidders take it, i made it in 5 minutes
local part = workspace.Obbies.WinParts:GetChildren()[3]
local player = game.Players.LocalPlayer

spawn(function()
    while wait() do
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if root and hum then
                hum.WalkToPoint = part.Position
                local bv = root:FindFirstChild("FloatVel")
                if not bv then
                    bv = Instance.new("BodyVelocity")
                    bv.Name = "FloatVel"
                    bv.MaxForce = Vector3.new(4000, 4000, 4000)
                    bv.Parent = root
                end
                bv.Velocity = (part.Position - root.Position).Unit * 30
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end
        task.wait()
    end
end)
