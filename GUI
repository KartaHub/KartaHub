			toggled = not toggled
			updateVisual()
			task.spawn(callback, toggled)
		end)

		table.insert(self.Tab.Elements, holder)

		return {
			Set = function(_, val)
				toggled = val
				updateVisual()
				task.spawn(callback, toggled)
			end,
			Get = function()
				return toggled
			end
		}
	end

	function Section:AddSlider(text, config, callback)
		local order = #self.Tab.Elements + 10
		config = config or {}
		callback = callback or function() end
		local min = config.Min or 0
		local max = config.Max or 100
		local default = config.Default or min
		local increment = config.Increment or 1
		local current = default

		local holder = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 46),
			BackgroundTransparency = 1,
			LayoutOrder = order,
			Parent = self.Frame
		})

		local label = Create("TextLabel", {
			Size = UDim2.new(1, -60, 0, 18),
			BackgroundTransparency = 1,
			Text = text,
			TextColor3 = Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = holder
		})

		local valueLabel = Create("TextLabel", {
			Size = UDim2.new(0, 55, 0, 18),
			Position = UDim2.new(1, -55, 0, 0),
			BackgroundTransparency = 1,
			Text = tostring(current),
			TextColor3 = Theme.Accent,
			Font = Enum.Font.GothamBold,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Right,
			Parent = holder
		})

		local sliderBg = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 8),
			Position = UDim2.new(0, 0, 0, 28),
			BackgroundColor3 = Theme.Slider_Bg,
			BorderSizePixel = 0,
			Parent = holder
		})
		Corner(sliderBg, 4)

		local fill = Create("Frame", {
			Size = UDim2.new((current - min) / (max - min), 0, 1, 0),
			BackgroundColor3 = Theme.Accent,
			BorderSizePixel = 0,
			Parent = sliderBg
		})
		Corner(fill, 4)

		local knob = Create("Frame", {
			Size = UDim2.new(0, 16, 0, 16),
			Position = UDim2.new((current - min) / (max - min), -8, 0.5, -8),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel = 0,
			ZIndex = 2,
			Parent = sliderBg
		})
		Corner(knob, 8)

		local sliderInput = Create("TextButton", {
			Size = UDim2.new(1, 0, 0, 24),
			Position = UDim2.new(0, 0, 0, 22),
			BackgroundTransparency = 1,
			Text = "",
			Parent = holder
		})

		local sliding = false

		local function update(inputPos)
			local relX = math.clamp((inputPos.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
			local raw = min + (max - min) * relX
			current = math.floor(raw / increment + 0.5) * increment
			current = math.clamp(current, min, max)
			local pct = (current - min) / (max - min)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			knob.Position = UDim2.new(pct, -8, 0.5, -8)
			valueLabel.Text = tostring(current)
		end

		sliderInput.MouseButton1Down:Connect(function()
			sliding = true
		end)

		UserInputService.InputChanged:Connect(function(input)
			if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
				update(input.Position)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and sliding then
				sliding = false
				task.spawn(callback, current)
			end
		end)

		sliderInput.MouseButton1Click:Connect(function()
			local mouse = UserInputService:GetMouseLocation()
			update(Vector2.new(mouse.X, mouse.Y))
			task.spawn(callback, current)
		end)

		table.insert(self.Tab.Elements, holder)

		return {
			Set = function(_, val)
				current = math.clamp(val, min, max)
				local pct = (current - min) / (max - min)
				fill.Size = UDim2.new(pct, 0, 1, 0)
				knob.Position = UDim2.new(pct, -8, 0.5, -8)
				valueLabel.Text = tostring(current)
				task.spawn(callback, current)
			end,
			Get = function()
				return current
			end
		}
	end

