						Color3.fromRGB(255,255,255), Color3.fromRGB(180,180,180), Color3.fromRGB(100,100,100),
						Color3.fromRGB(50,50,50), Color3.fromRGB(0,0,0),
						Color3.fromRGB(255,100,100), Color3.fromRGB(100,255,100), Color3.fromRGB(100,100,255),
						Color3.fromRGB(255,200,100), Color3.fromRGB(200,100,255), Color3.fromRGB(100,255,200),
					}

					local grid = Create("Frame", {
						Size = UDim2.new(1, -16, 1, -16),
						Position = UDim2.new(0, 8, 0, 8),
