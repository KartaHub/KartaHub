	function Section:AddParagraph(title, content)
		local order = #self.Tab.Elements + 10

		local holder = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundColor3 = Theme.Tertiary,
			BackgroundTransparency = 0.5,
			BorderSizePixel = 0,
			LayoutOrder = order,
			Parent = self.Frame
		})
		Corner(holder, 8)
		Padding(holder, 10, 10, 10, 10)

		local innerLayout = Create("UIListLayout", {
			Padding = UDim.new(0, 4),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = holder
		})

		if title and title ~= "" then
			Create("TextLabel", {
				Size = UDim2.new(1, 0, 0, 18),
				BackgroundTransparency = 1,
				Text = title,
				TextColor3 = Theme.Accent,
				Font = Enum.Font.GothamBold,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextWrapped = true,
				AutomaticSize = Enum.AutomaticSize.Y,
				LayoutOrder = 1,
				Parent = holder
			})
		end

		Create("TextLabel", {
			Size = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1,
			Text = content or "",
			TextColor3 = Theme.TextDim,
			Font = Enum.Font.Gotham,
			TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			AutomaticSize = Enum.AutomaticSize.Y,
			LayoutOrder = 2,
			Parent = holder
		})

		table.insert(self.Tab.Elements, holder)
	end

	return tab
end

function GuiMaker:SwitchTab(tab)
	if self.ActiveTab then
		self.ActiveTab.Container.Visible = false
		Tween(self.ActiveTab.Button, {BackgroundTransparency = 1, TextColor3 = Theme.TextDim}, 0.2)
	end

	self.ActiveTab = tab
	tab.Container.Visible = true
	Tween(tab.Button, {BackgroundTransparency = 0.6, TextColor3 = Theme.Text}, 0.2)
	tab.Button.BackgroundColor3 = Theme.Accent
end

function GuiMaker:Destroy()
	if self.ScreenGui then
		self.ScreenGui:Destroy()
	end
end

return GuiMaker
