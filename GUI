	function Section:AddDropdown(text, options, default, callback)
		local order = #self.Tab.Elements + 10
		callback = callback or function() end
		options = options or {}
		local selected = default or (options[1] or "")
		local open = false

		local holder = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 52),
			BackgroundTransparency = 1,
			ClipsDescendants = false,
			LayoutOrder = order,
			Parent = self.Frame
		})

		Create("TextLabel", {
			Size = UDim2.new(1, 0, 0, 18),
			BackgroundTransparency = 1,
			Text = text,
			TextColor3 = Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = holder
		})

		local dropBtn = Create("TextButton", {
			Size = UDim2.new(1, 0, 0, 30),
			Position = UDim2.new(0, 0, 0, 20),
			BackgroundColor3 = Theme.Input_Bg,
			Text = "  " .. tostring(selected),
			TextColor3 = Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			BorderSizePixel = 0,
			Parent = holder
		})
		Corner(dropBtn, 6)
		Stroke(dropBtn, Theme.Border, 1)

		local arrow = Create("TextLabel", {
			Size = UDim2.new(0, 20, 1, 0),
			Position = UDim2.new(1, -24, 0, 0),
			BackgroundTransparency = 1,
			Text = "v",
			TextColor3 = Theme.TextDim,
			Font = Enum.Font.GothamBold,
			TextSize = 11,
			Parent = dropBtn
		})

		local optionsList = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 0),
			Position = UDim2.new(0, 0, 0, 52),
			BackgroundColor3 = Theme.Input_Bg,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Visible = false,
			ZIndex = 10,
			Parent = holder
		})
		Corner(optionsList, 6)
		Stroke(optionsList, Theme.Border, 1)

		local optLayout = Create("UIListLayout", {
			Padding = UDim.new(0, 0),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = optionsList
		})

		local optionButtons = {}

		local function refreshOptions()
			for _, b in pairs(optionButtons) do
				b:Destroy()
			end
			optionButtons = {}

			for i, opt in ipairs(options) do
				local optBtn = Create("TextButton", {
					Size = UDim2.new(1, 0, 0, 28),
					BackgroundColor3 = Theme.Tertiary,
					BackgroundTransparency = opt == selected and 0.5 or 1,
					Text = "  " .. tostring(opt),
					TextColor3 = opt == selected and Theme.Accent or Theme.TextDim,
					Font = Enum.Font.Gotham,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					BorderSizePixel = 0,
					LayoutOrder = i,
					ZIndex = 10,
					Parent = optionsList
				})

				optBtn.MouseEnter:Connect(function()
					if opt ~= selected then
						Tween(optBtn, {BackgroundTransparency = 0.7}, 0.1)
					end
				end)
				optBtn.MouseLeave:Connect(function()
					if opt ~= selected then
						Tween(optBtn, {BackgroundTransparency = 1}, 0.1)
					end
				end)

				optBtn.MouseButton1Click:Connect(function()
					selected = opt
					dropBtn.Text = "  " .. tostring(opt)
					open = false
					optionsList.Visible = false
					holder.Size = UDim2.new(1, 0, 0, 52)
					arrow.Rotation = 0
					refreshOptions()
					task.spawn(callback, selected)
				end)

				table.insert(optionButtons, optBtn)
			end
		end

		refreshOptions()

		dropBtn.MouseButton1Click:Connect(function()
			open = not open
			if open then
				local totalH = #options * 28
				optionsList.Visible = true
				holder.Size = UDim2.new(1, 0, 0, 52 + totalH + 4)
				optionsList.Size = UDim2.new(1, 0, 0, totalH)
				arrow.Rotation = 180
			else
				optionsList.Visible = false
				holder.Size = UDim2.new(1, 0, 0, 52)
				arrow.Rotation = 0
			end
		end)

		table.insert(self.Tab.Elements, holder)

		return {
			Set = function(_, val)
				selected = val
				dropBtn.Text = "  " .. tostring(val)
				refreshOptions()
				task.spawn(callback, selected)
			end,
			Get = function()
				return selected
			end,
			Refresh = function(_, newOptions, newDefault)
				options = newOptions
				if newDefault then
					selected = newDefault
					dropBtn.Text = "  " .. tostring(newDefault)
				end
				refreshOptions()
			end
		}
	end

	function Section:AddKeybind(text, default, callback)
		local order = #self.Tab.Elements + 10
		callback = callback or function() end
		local currentKey = default or Enum.KeyCode.Unknown
		local listening = false

		local holder = Create("Frame", {
			Size = UDim2.new(1, 0, 0, 32),
			BackgroundTransparency = 1,
			LayoutOrder = order,
			Parent = self.Frame
		})

		Create("TextLabel", {
			Size = UDim2.new(1, -80, 1, 0),
			BackgroundTransparency = 1,
			Text = text,
			TextColor3 = Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = holder
		})

		local keyBtn = Create("TextButton", {
			Size = UDim2.new(0, 70, 0, 26),
			Position = UDim2.new(1, -72, 0.5, -13),
			BackgroundColor3 = Theme.Input_Bg,
			Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
			TextColor3 = Theme.Accent,
			Font = Enum.Font.GothamSemibold,
			TextSize = 12,
			BorderSizePixel = 0,
			Parent = holder
		})
		Corner(keyBtn, 6)
		Stroke(keyBtn, Theme.Border, 1)

		keyBtn.MouseButton1Click:Connect(function()
			listening = true
			keyBtn.Text = "..."
			Tween(keyBtn, {BackgroundColor3 = Theme.Accent}, 0.15)
			keyBtn.TextColor3 = Theme.Background
		end)

		UserInputService.InputBegan:Connect(function(input, gpe)
			if listening and input.UserInputType == Enum.UserInputType.Keyboard then
				listening = false
				currentKey = input.KeyCode
				keyBtn.Text = currentKey.Name
				keyBtn.TextColor3 = Theme.Accent
				Tween(keyBtn, {BackgroundColor3 = Theme.Input_Bg}, 0.15)
			elseif not gpe and input.KeyCode == currentKey then
				task.spawn(callback)
			end
		end)

		table.insert(self.Tab.Elements, holder)

		return {
			Set = function(_, key)
				currentKey = key
				keyBtn.Text = key.Name
			end,
			Get = function()
				return currentKey
			end
		}
	end

